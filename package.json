{
  "name": "dead-reckoning-memory-sea",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx server/index.ts\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist/server/server/index.js",
    "lint": "eslint . --ext .ts && tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:seed": "tsx scripts/seed-db.ts",
    "db:reset": "tsx scripts/seed-db.ts --reset",
    "generate:tokens": "tsx scripts/generate-tokens.ts"
  },
  "dependencies": {
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8"
  }
}
